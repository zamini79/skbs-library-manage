# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # 서버 사이드 전용 (절대 노출 금지)

# 관리자 인증 (시크릿 생성: openssl rand -hex 32)
ADMIN_JWT_SECRET=

# Vercel Cron (시크릿 생성: openssl rand -hex 32)
CRON_SECRET=                            # /api/cron/* 보호용

# Supabase 타입 자동 생성용 (npm run types:gen)
SUPABASE_PROJECT_ID=

# Google Books API 키 — 책 표지 자동 조회용
# 발급: console.cloud.google.com → API & Services → Library → Books API 활성화 → Credentials
GOOGLE_BOOKS_API_KEY=

# Kakao Book Search REST API 키 — Google 미매칭 시 폴백 (한국 책 커버리지 우수)
# 발급: developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_API_KEY=

# Naver 책 검색 API — Kakao 미매칭 시 폴백 (한국 출판사 공식 표지)
# 발급: developers.naver.com → 애플리케이션 등록 → "검색" API 추가
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
