# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # 서버 사이드 전용 (절대 노출 금지)

# 운영 배포 URL — 회원가입 인증 메일의 confirm 링크가 향하는 origin.
# 비워두면 가입 폼이 띄워진 브라우저의 location.origin 사용 (로컬 개발용 fallback).
# 운영(Vercel)에서는 반드시 설정 — 그래야 다른 PC에서 메일을 열어도 운영 도메인으로 이동.
NEXT_PUBLIC_SITE_URL=https://skbs-library-manage.vercel.app

# 관리자 인증 (시크릿 생성: openssl rand -hex 32)
ADMIN_JWT_SECRET=

# Vercel Cron (시크릿 생성: openssl rand -hex 32)
CRON_SECRET=                            # /api/cron/* 보호용

# Supabase 타입 자동 생성용 (npm run types:gen)
SUPABASE_PROJECT_ID=

# Google Books API 키 — 책 표지 자동 조회용
# 발급: console.cloud.google.com → API & Services → Library → Books API 활성화 → Credentials
GOOGLE_BOOKS_API_KEY=

# Kakao Book Search REST API 키 — Google 미매칭 시 폴백 (한국 책 커버리지 우수)
# 발급: developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_API_KEY=

# Naver 책 검색 API — Kakao 미매칭 시 폴백 (한국 출판사 공식 표지)
# 발급: developers.naver.com → 애플리케이션 등록 → "검색" API 추가
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 알림 메일 SMTP — Supabase Auth 의 Custom SMTP 와 동일한 자격증명을 사용한다
# (회원가입 인증 메일과 발송자 일치 목적). /api/cron/rental-notifications 가 사용.
# Supabase Auth Settings → SMTP Settings 에 동일 값을 설정 후, 여기에도 그대로 입력.
SMTP_HOST=
SMTP_PORT=587                            # 465(implicit TLS) / 587(STARTTLS) 권장
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SK Bioscience 사내 도서관 <no-reply@your-domain>"
# SMTP_SECURE=                          # 비워두면 PORT=465 일 때만 secure 자동 활성
